# Google Gemini AI (Required for core intelligence)
GOOGLE_GENERATIVE_AI_API_KEY=

# Deepgram Voice AI (TTS for podcast generation)
DEEPGRAM_API_KEY=

# Web Scraper integrations (Choose One)
FIRECRAWL_API_KEY=
CRAWL4AI_API_URL=https://your-custom-crawl4ai-api.com

# PostgreSQL Database (Neon DB recommended)
DATABASE_URL=postgresql://user:password@hostname/db?sslmode=require

# DigitalOcean Spaces (S3 for storing generated audio)
DO_SPACES_KEY=
DO_SPACES_SECRET=
DO_SPACES_ENDPOINT=
DO_SPACES_BUCKET=

# Upstash Redis (For rate-limiting or state caching)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Slack Integration (Optional for notifications)
SLACK_WEBHOOK_URL=

# Cloudflare Workers AI (Optional/Deprecated)
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=
